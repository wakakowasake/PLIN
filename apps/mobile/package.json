{
  "name": "plin-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "start:ios": "expo start --ios --localhost",
    "start:tunnel": "expo start --tunnel",
    "start:workaround": "EXPO_PUBLIC_PLIN_IOS_DEV_WORKAROUND=1 expo start --dev-client --lan",
    "start:workaround:tunnel": "EXPO_PUBLIC_PLIN_IOS_DEV_WORKAROUND=1 expo start --dev-client --tunnel",
    "android": "expo run:android",
    "eas-build-pre-install": "node ./scripts/validate-android-release-env.mjs",
    "prebuild:android-release-env": "node ./scripts/validate-android-release-env.mjs",
    "android:release:arm": "npm run prebuild:android-release-env && cd android && NODE_ENV=production JAVA_HOME=$(/usr/libexec/java_home -v 17 2>/dev/null || printf \"%s\" \"$JAVA_HOME\") ./gradlew assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a",
    "android:bundle:arm": "npm run prebuild:android-release-env && cd android && NODE_ENV=production JAVA_HOME=$(/usr/libexec/java_home -v 17 2>/dev/null || printf \"%s\" \"$JAVA_HOME\") ./gradlew app:bundleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a",
    "ios": "expo run:ios",
    "ios:workaround": "EXPO_PUBLIC_PLIN_IOS_DEV_WORKAROUND=1 expo run:ios --no-build-cache",
    "ios:release": "expo run:ios --configuration Release",
    "web": "expo start --web",
    "export:web": "EXPO_PUBLIC_PLIN_WEB_BASE_PATH=/m expo export --platform web --output-dir ../../dist/m",
    "test": "tsc -p tsconfig.tests.json && node --test ./.tmp-tests/tests",
    "typecheck": "tsc --noEmit",
    "audit:spacing": "node ./scripts/spacing-audit.mjs",
    "report:radius-full": "node ./scripts/radius-full-report.mjs",
    "report:copy-audit": "node ./scripts/export-copy-audit.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~55.0.6",
    "expo-apple-authentication": "^55.0.13",
    "expo-auth-session": "~55.0.8",
    "expo-crypto": "~55.0.9",
    "expo-document-picker": "~55.0.13",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.14",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.17",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "firebase": "^12.9.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "~5.9.2"
  }
}
