{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./.tmp-tests",
    "rootDir": "./",
    "noEmit": false,
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "jsx": "react-jsx",
    "esModuleInterop": true
  },
  "include": [
    "src/config/runtime-gate.ts",
    "src/auth/mandatory-agreement.ts",
    "src/utils/pagination.ts",
    "src/utils/mobile-web-session-paths.ts",
    "src/utils/trip-invite-link.ts",
    "src/utils/trip-invite-response.ts",
    "tests/**/*.test.ts"
  ]
}
