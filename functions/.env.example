# Google Maps API Key
# https://console.cloud.google.com/apis/credentials
# Server-side Google Maps Web Services key
# Used for Places / Routes / Geocoding calls from Cloud Functions
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Browser Google Maps JavaScript / Embed key
# Used by the web app for Maps JavaScript API and Maps Embed API
# Remember to allow the correct HTTP referrers such as:
# - https://plin.ink/*
# - https://www.plin.ink/*
# - https://plin-db93d.web.app/*
# - https://plin-db93d.firebaseapp.com/*
GOOGLE_MAPS_BROWSER_API_KEY=your_google_maps_browser_api_key_here

# Firebase API Key
# Firebase Console > Project Settings > General
PLIN_FIREBASE_API_KEY=your_firebase_api_key_here

# Optional public API base URL override for OAuth callbacks
# Current default is https://plin.ink/api when omitted.
# PLIN_PUBLIC_API_BASE_URL=https://asia-northeast3-plin-db93d.cloudfunctions.net/api

# Unsplash Access Key
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Kakao Login
# https://developers.kakao.com/
# Kakao OAuth request uses the parameter name client_id,
# and the value to put there is your Kakao REST API key.
# You can set either KAKAO_CLIENT_ID or KAKAO_REST_API_KEY.
# With the default callback base URL, register this exact Redirect URI:
# https://plin.ink/api/auth/social/mobile-complete
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
# KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
# Optional for Kakao token exchange when enabled in the Kakao console
# KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
# Optional admin key for Kakao unlink/revoke on account deletion
# KAKAO_ADMIN_KEY=your_kakao_admin_key_here

# NAVER Login
# https://developers.naver.com/
# Required for NAVER sign-in start/exchange flow
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Apple Login
# Apple Developer > Identifiers > Services ID
# Used for Android Apple sign-in through the Functions callback.
# Defaults to ink.plin.mobile.signin when omitted.
# PLIN_APPLE_SERVICE_ID=ink.plin.mobile.signin

# Ekispert API Key (일본 철도 경로 검색)
# https://ekispert.com/
# 로컬 개발용으로만 functions/.env.local 에 넣어주세요.
# 배포 환경은 Firebase Secret Manager의 EKISPERT_API_KEY 를 사용합니다.
# EKISPERT_API_KEY=your_ekispert_api_key_here

# 사용 방법:
# 1. 이 파일을 복사하여 .env 파일 생성: cp .env.example .env
# 2. 각 API 키를 실제 값으로 교체
# 3. .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 포함됨)
